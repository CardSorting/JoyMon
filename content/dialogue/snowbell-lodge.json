  "dialogues": [
    {
      "id": "frostveil-trainer-1-talk",
      "speaker": "Snowline Trainer",
      "lines": [
        "The snow grass ahead hides Frost-type JoyMon.",
        "I'll battle you once the lodge posts the route permits."
      ]
    },
    {
      "id": "frostveil-trainer-2-talk",
      "speaker": "Ice Patch Trainer",
      "lines": [
        "These ice patches look harmless until you lose your footing.",
        "Come back later and I'll test your balance in battle."
      ]
    },
    {
      "id": "snowbell-healer-talk",
      "speaker": "Lodge Medic",
      "lines": [
        "Cold drains a party faster than a long fight.",
        "Warm up here. Your JoyMon are healed."
      ]
    },
    {
      "id": "snowbell-keeper-talk",
      "speaker": "Lodge Keeper",
      "lines": [
        "Welcome to Snowbell Lodge.",
        "The mountain lift is running again, so travelers from Ashbend can finally reach us."
      ]
    },
    {
      "id": "snowbell-scout-talk",
      "speaker": "Ridge Scout",
      "lines": [
        "Snobble hold the path when storms blow in.",
        "Chilleaf stay near green breaks in the snow."
      ]
    },
    {
      "id": "snowbell-guest-talk",
      "speaker": "Snowbound Guest",
      "lines": [
        "I saw Staticrow sparking through the snowfall.",
        "Even familiar JoyMon behave differently this high up."
      ]
    },
    {
      "id": "snowbell-shrine-gate-talk",
      "speaker": "Shrine Entrance",
      "lines": [
        "The shrine path is sealed by packed snow and old ice.",
        "A formal expedition will be needed before anyone goes farther."
      ]
    }
  ]
